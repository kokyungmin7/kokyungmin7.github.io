---
import ComingSoonPage from '../components/ComingSoonPage.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getBlogDataset } from '../data/blog';
import BlogSectionLayout from '../layouts/BlogSectionLayout.astro';

const { recentPosts, searchEntries, categorySummaries } = await getBlogDataset();
---

<BlogSectionLayout
	title={SITE_TITLE}
	description={SITE_DESCRIPTION}
	searchEntries={searchEntries}
	categorySummaries={categorySummaries}
	recentPosts={recentPosts}
>
	<ComingSoonPage />
</BlogSectionLayout>
