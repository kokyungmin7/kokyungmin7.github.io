---
import BlogPostList from '../../components/BlogPostList.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { getBlogDataset } from '../../data/blog';
import BlogSectionLayout from '../../layouts/BlogSectionLayout.astro';

const { posts, recentPosts, searchEntries, categorySummaries } = await getBlogDataset();
---

<BlogSectionLayout
	title={`Blog — ${SITE_TITLE}`}
	description={SITE_DESCRIPTION}
	searchEntries={searchEntries}
	categorySummaries={categorySummaries}
	recentPosts={recentPosts}
>
	<div class="page-header">
		<h1>Blog</h1>
		<p class="post-count">{posts.length}개의 포스트</p>
	</div>
	<BlogPostList posts={posts} />
</BlogSectionLayout>

<style>
	.page-header {
		display: flex;
		align-items: baseline;
		gap: 1rem;
	}
	.post-count {
		font-size: 1em;
		color: var(--text-muted);
		margin: 0;
	}

	@media (max-width: 600px) {
		.page-header {
			flex-direction: column;
			gap: 0.25rem;
		}
	}
</style>
