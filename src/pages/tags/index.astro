---
import PageHeader from '../../components/PageHeader.astro';
import TagCloud from '../../components/TagCloud.astro';
import { SITE_TITLE } from '../../consts';
import { getBlogDataset } from '../../data/blog';
import BlogSectionLayout from '../../layouts/BlogSectionLayout.astro';

const { tagSummaries, searchEntries } = await getBlogDataset();
---

<BlogSectionLayout
	title={`Tags — ${SITE_TITLE}`}
	description="모든 태그 보기"
	searchEntries={searchEntries}
>
	<PageHeader title="Tags" description={`${tagSummaries.length}개의 태그`} />

	{tagSummaries.length === 0 ? (
		<div class="empty-state">
			<p>아직 태그가 없습니다.</p>
			<p class="empty-hint">
				포스트 프론트매터에 <code>tags: [태그명]</code> 을 추가하면 여기에 표시됩니다.
			</p>
		</div>
	) : (
		<TagCloud tags={tagSummaries} />
	)}
</BlogSectionLayout>
