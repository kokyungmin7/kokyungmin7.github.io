---
import FormattedDate from './FormattedDate.astro';
import type { BlogCategorySummary, BlogPostEntry } from '../data/blog';

interface Props {
	currentCategory?: string;
	categorySummaries: BlogCategorySummary[];
	recentPosts: BlogPostEntry[];
}

const { currentCategory, categorySummaries, recentPosts } = Astro.props;
const currentPath = Astro.url.pathname;
---

<div class="sidebar-container" id="sidebar-container">
	<button class="toggle-btn" id="sidebar-toggle" aria-label="사이드바 접기/펼치기">
		<div class="btn-icon">
			<span class="line line-1"></span>
			<span class="line line-2"></span>
		</div>
	</button>

	<div class="sidebar-panel" id="sidebar-panel">
		<div class="sidebar-section sidebar-section--categories glass-panel">
			<h3 class="sidebar-title">카테고리</h3>
			<ul class="category-list">
				{categorySummaries.map((category) => (
					<li>
						<a
							href="/blog"
							class:list={[
								'sidebar-nav-item',
								'category-link',
								{
									active:
										category.name === (currentCategory ?? '전체') &&
										currentPath.startsWith('/blog'),
								},
							]}
						>
							<span class="category-name">{category.name}</span>
							<span class="category-count">{category.count}</span>
						</a>
					</li>
				))}
			</ul>
		</div>

		<div class="sidebar-section sidebar-section--recent glass-panel">
			<h3 class="sidebar-title">최신 글</h3>
			<ul class="recent-list">
				{recentPosts.map((post) => (
					<li>
						<a
							href={`/blog/${post.id}/`}
							class:list={['sidebar-nav-item', 'recent-link', { active: currentPath === `/blog/${post.id}/` }]}
						>
							<span class="recent-title">{post.data.title}</span>
							<span class="recent-date"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</div>

		<a
			href="/tags"
			class:list={['tags-link', 'glass-panel', 'hover-underline-link', { active: currentPath.startsWith('/tags') }]}
		>
			# 태그 보기
		</a>
	</div>
</div>

<script>
	const container = document.getElementById('sidebar-container') as HTMLElement | null;
	const toggleButton = document.getElementById('sidebar-toggle') as HTMLButtonElement | null;

	function setCollapsed(collapsed: boolean, animate = true) {
		if (!container) return;

		if (!animate) container.classList.add('no-transition');

		if (collapsed) {
			container.classList.add('collapsed');
			document.documentElement.classList.add('sidebar-collapsed');
		} else {
			container.classList.remove('collapsed');
			document.documentElement.classList.remove('sidebar-collapsed');
		}

		if (!animate) {
			container.getBoundingClientRect();
			container.classList.remove('no-transition');
		}

		localStorage.setItem('sidebar-collapsed', String(collapsed));
	}

	if (localStorage.getItem('sidebar-collapsed') === 'true') {
		setCollapsed(true, false);
	}

	toggleButton?.addEventListener('click', () => {
		if (!container) return;
		setCollapsed(!container.classList.contains('collapsed'));
	});
</script>

<style>
	.sidebar-container {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		flex-shrink: 0;
		position: sticky;
		top: var(--header-height);
		align-self: flex-start;
		max-height: calc(100vh - 100px);
		margin-right: 6rem;
		transition: margin-right 0.3s ease;
	}

	.sidebar-container.collapsed,
	:global(html.sidebar-collapsed) .sidebar-container {
		margin-right: 3rem;
	}

	.sidebar-container.no-transition,
	.sidebar-container.no-transition .sidebar-panel,
	.sidebar-container.no-transition .toggle-btn .line {
		transition: none !important;
	}

	.toggle-btn {
		flex-shrink: 0;
		align-self: flex-start;
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0.25em;
		margin-right: 0.5rem;
		outline: none;
		user-select: none;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.btn-icon {
		position: relative;
		width: 1.3em;
		height: 0.75em;
	}

	.line {
		display: block;
		position: absolute;
		width: 100%;
		top: 50%;
		background: var(--text-muted);
		height: 0.14em;
		border-radius: 10em;
		transition: transform 0.3s ease, background 0.15s ease;
	}

	.toggle-btn:hover .line {
		background: var(--accent);
	}

	.toggle-btn .line-1 {
		transform: translateY(-50%) rotate(45deg);
	}

	.toggle-btn .line-2 {
		transform: translateY(-50%) rotate(-45deg);
	}

	.sidebar-container.collapsed .toggle-btn .line-1,
	:global(html.sidebar-collapsed) .toggle-btn .line-1 {
		transform: translateY(calc(-50% - 4px)) rotate(0deg);
	}

	.sidebar-container.collapsed .toggle-btn .line-2,
	:global(html.sidebar-collapsed) .toggle-btn .line-2 {
		transform: translateY(calc(-50% + 4px)) rotate(0deg);
	}

	.sidebar-panel {
		width: 260px;
		max-height: calc(100vh - 100px);
		overflow-y: auto;
		overflow-x: hidden;
		transition: width 0.3s ease, opacity 0.2s ease;
		scrollbar-width: thin;
		scrollbar-color: var(--border) transparent;
	}

	.sidebar-container.collapsed .sidebar-panel,
	:global(html.sidebar-collapsed) .sidebar-panel {
		width: 0;
		opacity: 0;
		pointer-events: none;
		transition: width 0.3s ease, opacity 0.15s ease;
	}

	.sidebar-section {
		border-radius: 1rem;
		padding: 1.25rem;
		margin-bottom: 0.9rem;
	}

	.sidebar-title {
		font-size: 0.82em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-muted);
		margin: 0 0 0.9rem 0;
	}

	.sidebar-section--categories .sidebar-title,
	.sidebar-section--recent .sidebar-title {
		color: var(--text-muted);
		margin: 0 0 0.9rem 0;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.category-list,
	.recent-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.category-link {
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		box-sizing: border-box;
	}

	.category-count {
		font-size: 0.8em;
		background: color-mix(in srgb, var(--text-muted) 20%, transparent);
		color: var(--text-muted);
		border-radius: 10px;
		padding: 0 0.45em;
		line-height: 1.5;
		flex-shrink: 0;
	}
	.category-link.active .category-count {
		color: var(--sidebar-list-active-color);
	}

	.recent-link {
		display: flex;
		flex-direction: column;
		gap: 0.15em;
		width: 100%;
		box-sizing: border-box;
	}
	.recent-link:hover .recent-title {
		color: var(--text);
	}
	.recent-link.active .recent-title {
		color: var(--sidebar-list-active-color);
		font-weight: 600;
	}
	.recent-title {
		font-size: 0.92em;
		color: var(--text-muted);
		line-height: 1.3;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		transition: color 0.15s ease;
	}
	.recent-date {
		font-size: 0.8em;
		color: var(--text-muted);
	}

	.tags-link.hover-underline-link {
		padding-bottom: 0.65em;
	}

	.tags-link {
		display: block;
		padding: 0.6em 0.75em 0.65em;
		border-radius: 1rem;
		font-size: 0.85em;
		color: var(--text-muted);
		text-decoration: none;
		text-align: center;
		transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
		white-space: nowrap;
	}
	.tags-link:hover,
	.tags-link.active {
		color: var(--text);
		border-color: var(--border);
		background-color: var(--glass-bg);
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.sidebar-container {
			display: none;
		}
	}
</style>
