---
import type { BlogCategoryTree, BlogPostEntry } from '../data/blog';
import SidebarToggle from './sidebar/SidebarToggle.astro';
import SidebarNavItem from './sidebar/SidebarNavItem.astro';
import SidebarBlogContent from './sidebar/SidebarBlogContent.astro';

interface Props {
	currentCategory?: string;
	currentSubcategory?: string;
	categoryTree: BlogCategoryTree[];
	recentPosts: BlogPostEntry[];
}

const { currentCategory, currentSubcategory, categoryTree, recentPosts } = Astro.props;
const currentPath = Astro.url.pathname;
const isBlogSection = currentPath.startsWith('/blog') || currentPath.startsWith('/tags');

const siteNav = [
	{
		href: '/', label: 'HOME', active: currentPath === '/',
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
	},
	{
		href: '/blog', label: 'BLOG', active: currentPath.startsWith('/blog'),
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>`,
	},
	{
		href: '/projects', label: 'PROJECTS', active: currentPath.startsWith('/projects'),
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>`,
	},
	{
		href: '/about', label: 'ABOUT', active: currentPath.startsWith('/about'),
		icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
	},
];
---

<div class="sidebar-container" id="sidebar-container">
	<div class="sidebar-panel" id="sidebar-panel">
		<SidebarToggle />

		<div class="panel-divider"></div>

		<nav class="site-nav" aria-label="사이트 내비게이션">
			{siteNav.map((item) => (
				<>
					<SidebarNavItem
						href={item.href}
						label={item.label}
						icon={item.icon}
						active={item.active}
					/>
					<div class="panel-divider"></div>
				</>
			))}
		</nav>

		<SidebarBlogContent
			categoryTree={categoryTree}
			recentPosts={recentPosts}
			currentPath={currentPath}
			currentCategory={currentCategory}
			currentSubcategory={currentSubcategory}
			isBlogSection={isBlogSection}
		/>
	</div>
</div>

<script>
	const container = document.getElementById('sidebar-container') as HTMLElement | null;
	const toggleLabel = document.getElementById('sidebar-toggle-label') as HTMLLabelElement | null;
	const checkbox = document.getElementById('sidebar-checkbox') as HTMLInputElement | null;

	function setCollapsed(collapsed: boolean, animate = true) {
		if (!container) return;

		if (!animate) {
			container.classList.add('no-transition');
			toggleLabel?.classList.add('no-animate');
		}

		if (collapsed) {
			container.classList.add('collapsed');
			document.documentElement.classList.add('sidebar-collapsed');
			if (checkbox) checkbox.checked = false;
		} else {
			container.classList.remove('collapsed');
			document.documentElement.classList.remove('sidebar-collapsed');
			if (checkbox) checkbox.checked = true;
		}

		if (!animate) {
			container.getBoundingClientRect();
			container.classList.remove('no-transition');
			toggleLabel?.classList.remove('no-animate');
		}

		localStorage.setItem('sidebar-collapsed', String(collapsed));
	}

	// 초기 상태 설정
	const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
	if (isCollapsed) {
		setCollapsed(true, false);
	} else {
		if (checkbox) checkbox.checked = true;
	}

	checkbox?.addEventListener('change', () => {
		const nowCollapsed = !checkbox.checked;
		setCollapsed(nowCollapsed);

		if (!nowCollapsed) {
			// 펼칠 때: SidebarNavItem에 알림 → chars 슬라이드업
			window.dispatchEvent(new Event('sidebar:expanded'));
		}
	});
</script>

<style>
	/* ── 컨테이너 ── */
	.sidebar-container {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		flex-shrink: 0;
		position: sticky;
		top: 0;
		height: 100vh;
		align-self: flex-start;
		margin-right: 2rem;
		transition: margin-right 0.3s ease;
	}

	.sidebar-container.collapsed,
	:global(html.sidebar-collapsed) .sidebar-container {
		margin-right: 1rem;
	}

	.sidebar-container.no-transition,
	.sidebar-container.no-transition .sidebar-panel {
		transition: none !important;
	}

	/* ── 메인 패널 ── */
	.sidebar-panel {
		width: 300px;
		height: 100vh;
		overflow-y: auto;
		overflow-x: hidden;
		background: #181818;
		border-radius: 0;
		transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		scrollbar-width: thin;
		scrollbar-color: rgba(255, 255, 255, 0.1) transparent;
	}

	.sidebar-container.collapsed .sidebar-panel,
	:global(html.sidebar-collapsed) .sidebar-panel {
		width: 64px;
	}

	/* ── 구분선 ── */
	.panel-divider {
		height: 1px;
		background: rgba(255, 255, 255, 0.07);
		margin: 0;
		border: none;
	}

	/* ── 사이트 내비게이션 ── */
	.site-nav {
		display: flex;
		flex-direction: column;
	}

	/* ── 반응형 ── */
	@media (max-width: 768px) {
		.sidebar-container {
			display: none;
		}
	}
</style>
