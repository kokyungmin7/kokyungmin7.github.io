---
import type { BlogCategoryTree, BlogPostEntry } from '../data/blog';
import { isActivePath, SITE_NAV_ITEMS } from '../data/navigation';
import SidebarToggle from './sidebar/SidebarToggle.astro';
import SidebarNavItem from './sidebar/SidebarNavItem.astro';
import SidebarBlogContent from './sidebar/SidebarBlogContent.astro';
import ThemeToggle from './sidebar/ThemeToggle.astro';

interface Props {
	currentCategory?: string;
	currentSubcategory?: string;
	categoryTree: BlogCategoryTree[];
	recentPosts: BlogPostEntry[];
}

const { currentCategory, currentSubcategory, categoryTree, recentPosts } = Astro.props;
const currentPath = Astro.url.pathname;
const isBlogSection = currentPath.startsWith('/blog') || currentPath.startsWith('/tags');
const siteNav = SITE_NAV_ITEMS.map((item) => ({
	...item,
	active: isActivePath(currentPath, item),
}));
---

<div class="sidebar-container" id="sidebar-container">
	<div class="sidebar-panel" id="sidebar-panel">
		<SidebarToggle />

		<div class="panel-divider"></div>

		<nav class="site-nav" aria-label="사이트 내비게이션">
			{siteNav.map((item) => (
				<>
					<SidebarNavItem
						href={item.href}
						label={item.sidebarLabel}
						icon={item.icon}
						active={item.active}
					/>
					<div class="panel-divider"></div>
				</>
			))}
		</nav>
		<ThemeToggle />
		<div class="panel-divider"></div>

		<SidebarBlogContent
			categoryTree={categoryTree}
			recentPosts={recentPosts}
			currentPath={currentPath}
			currentCategory={currentCategory}
			currentSubcategory={currentSubcategory}
			isBlogSection={isBlogSection}
		/>
	</div>
</div>

<script>
	const container = document.getElementById('sidebar-container') as HTMLElement | null;
	const toggleLabel = document.getElementById('sidebar-toggle-label') as HTMLLabelElement | null;
	const checkbox = document.getElementById('sidebar-checkbox') as HTMLInputElement | null;
	const toggleAnimationMs = 500;

	function animateToggle() {
		if (!toggleLabel) return;

		toggleLabel.classList.remove('is-animating');
		toggleLabel.getBoundingClientRect();
		toggleLabel.classList.add('is-animating');
		window.setTimeout(() => {
			toggleLabel.classList.remove('is-animating');
		}, toggleAnimationMs);
	}

	function setCollapsed(collapsed: boolean, animate = true) {
		if (!container) return;

		if (!animate) {
			container.classList.add('no-transition');
			toggleLabel?.classList.add('no-animate');
		}

		if (collapsed) {
			container.classList.add('collapsed');
			document.documentElement.classList.add('sidebar-collapsed');
			if (checkbox) checkbox.checked = false;
		} else {
			container.classList.remove('collapsed');
			document.documentElement.classList.remove('sidebar-collapsed');
			if (checkbox) checkbox.checked = true;
		}

		if (!animate) {
			container.getBoundingClientRect();
			container.classList.remove('no-transition');
			toggleLabel?.classList.remove('no-animate');
		}

		localStorage.setItem('sidebar-collapsed', String(collapsed));
	}

	// 초기 상태 설정
	const isCollapsed = localStorage.getItem('sidebar-collapsed') === 'true';
	if (isCollapsed) {
		setCollapsed(true, false);
	} else {
		toggleLabel?.classList.add('no-animate');
		if (checkbox) checkbox.checked = true;
		container?.getBoundingClientRect();
		toggleLabel?.classList.remove('no-animate');
	}

	checkbox?.addEventListener('change', () => {
		animateToggle();
		const nowCollapsed = !checkbox.checked;
		setCollapsed(nowCollapsed);

		if (!nowCollapsed) {
			// 펼칠 때: SidebarNavItem에 알림 → chars 슬라이드업
			window.dispatchEvent(new Event('sidebar:expanded'));
		}
	});
</script>

<style>
	/* ── 컨테이너 ── */
	.sidebar-container {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		flex-shrink: 0;
		position: sticky;
		top: 0;
		height: 100vh;
		align-self: flex-start;
		margin-right: 2rem;
		transition: margin-right 0.3s ease;
	}

	.sidebar-container.collapsed,
	:global(html.sidebar-collapsed) .sidebar-container {
		margin-right: 1rem;
	}

	.sidebar-container.no-transition,
	.sidebar-container.no-transition .sidebar-panel {
		transition: none !important;
	}

	/* ── 메인 패널 ── */
	.sidebar-panel {
		width: 300px;
		height: 100vh;
		overflow-y: auto;
		overflow-x: hidden;
		background: var(--sidebar-bg);
		border-radius: 0;
		transition: width 0.3s cubic-bezier(0.4, 0, 0.2, 1), background 0.3s ease;
		scrollbar-width: thin;
		scrollbar-color: var(--sidebar-divider) transparent;
	}

	.sidebar-container.collapsed .sidebar-panel,
	:global(html.sidebar-collapsed) .sidebar-panel {
		width: 64px;
	}

	/* ── 구분선 ── */
	.panel-divider {
		height: 1px;
		background: var(--sidebar-divider);
		margin: 0;
		border: none;
	}

	/* ── 사이트 내비게이션 ── */
	.site-nav {
		display: flex;
		flex-direction: column;
	}

	/* ── 반응형 ── */
	@media (max-width: 768px) {
		.sidebar-container {
			display: none;
		}
	}
</style>
