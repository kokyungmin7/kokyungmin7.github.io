---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	currentCategory?: string;
}

const { currentCategory } = Astro.props;

const currentPath = Astro.url.pathname;

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categoryMap = new Map<string, number>();
for (const post of allPosts) {
	const cat = post.data.category ?? '일반';
	categoryMap.set(cat, (categoryMap.get(cat) ?? 0) + 1);
}
const categories = [
	{ name: '전체', count: allPosts.length },
	...Array.from(categoryMap.entries()).map(([name, count]) => ({ name, count })),
];

const recentPosts = allPosts.slice(0, 5);
---

<div class="sidebar-container" id="sidebar-container">
	<div class="sidebar-panel" id="sidebar-panel">
		<!-- Categories -->
		<div class="sidebar-section">
			<h3 class="sidebar-title">카테고리</h3>
			<ul class="category-list">
				{categories.map((cat) => (
					<li>
						<a
							href="/blog"
							class:list={['category-link', {
								active: cat.name === (currentCategory ?? '전체') && currentPath.startsWith('/blog'),
							}]}
						>
							<span class="category-name">{cat.name}</span>
							<span class="category-count">{cat.count}</span>
						</a>
					</li>
				))}
			</ul>
		</div>

		<!-- Recent Posts -->
		<div class="sidebar-section">
			<h3 class="sidebar-title">최신 글</h3>
			<ul class="recent-list">
				{recentPosts.map((post) => (
					<li>
						<a
							href={`/blog/${post.id}/`}
							class:list={['recent-link', { current: currentPath === `/blog/${post.id}/` }]}
						>
							<span class="recent-title">{post.data.title}</span>
							<span class="recent-date"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</div>

		<!-- Tags link -->
		<a
			href="/tags"
			class:list={['tags-link', { active: currentPath.startsWith('/tags') }]}
		>
			# 태그 보기
		</a>
	</div>

	<!-- Toggle button -->
	<button class="toggle-btn" id="sidebar-toggle" aria-label="사이드바 접기/펼치기">
		<span id="toggle-icon">‹</span>
	</button>
</div>

<script>
	const container = document.getElementById('sidebar-container') as HTMLElement;
	const toggleIcon = document.getElementById('toggle-icon') as HTMLElement;
	const toggleBtn = document.getElementById('sidebar-toggle') as HTMLButtonElement;

	function setCollapsed(collapsed: boolean, animate = true) {
		if (!animate) container.classList.add('no-transition');
		if (collapsed) {
			container.classList.add('collapsed');
			toggleIcon.textContent = '›';
			toggleBtn.setAttribute('aria-label', '사이드바 펼치기');
		} else {
			container.classList.remove('collapsed');
			toggleIcon.textContent = '‹';
			toggleBtn.setAttribute('aria-label', '사이드바 접기');
		}
		if (!animate) {
			// force reflow then re-enable transition
			container.getBoundingClientRect();
			container.classList.remove('no-transition');
		}
		localStorage.setItem('sidebar-collapsed', String(collapsed));
	}

	// Restore state without animation to avoid flash
	const saved = localStorage.getItem('sidebar-collapsed');
	if (saved === 'true') setCollapsed(true, false);

	toggleBtn.addEventListener('click', () => {
		setCollapsed(!container.classList.contains('collapsed'));
	});
</script>

<style>
	.sidebar-container {
		display: flex;
		align-items: flex-start;
		flex-shrink: 0;
		position: sticky;
		top: 80px;
		align-self: flex-start;
		max-height: calc(100vh - 100px);
	}

	.sidebar-container.no-transition,
	.sidebar-container.no-transition .sidebar-panel {
		transition: none !important;
	}

	.sidebar-panel {
		width: 200px;
		max-height: calc(100vh - 100px);
		overflow-y: auto;
		overflow-x: hidden;
		transition: width 0.3s ease, opacity 0.2s ease;
		scrollbar-width: thin;
		scrollbar-color: var(--border) transparent;
	}

	.sidebar-container.collapsed .sidebar-panel {
		width: 0;
		opacity: 0;
		pointer-events: none;
		transition: width 0.3s ease, opacity 0.15s ease;
	}

	/* Sidebar sections */
	.sidebar-section {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 10px;
		padding: 1rem;
		margin-bottom: 0.75rem;
	}

	.sidebar-title {
		font-size: 0.72em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-muted);
		margin: 0 0 0.75rem 0;
	}

	/* Category list */
	.category-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.category-link {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0.3em 0.5em;
		border-radius: 5px;
		text-decoration: none;
		font-size: 0.85em;
		color: var(--text-muted);
		transition: background-color 0.15s ease, color 0.15s ease;
	}
	.category-link:hover {
		background-color: var(--accent-dim);
		color: var(--text);
		text-decoration: none;
	}
	.category-link.active {
		background-color: var(--accent-dim);
		color: var(--accent);
	}
	.category-count {
		font-size: 0.8em;
		background: var(--border);
		color: var(--text-muted);
		border-radius: 10px;
		padding: 0 0.45em;
		line-height: 1.5;
		flex-shrink: 0;
	}

	/* Recent posts */
	.recent-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.4rem;
	}

	.recent-link {
		display: flex;
		flex-direction: column;
		gap: 0.1em;
		padding: 0.35em 0.5em;
		border-radius: 5px;
		text-decoration: none;
		transition: background-color 0.15s ease;
	}
	.recent-link:hover {
		background-color: var(--accent-dim);
		text-decoration: none;
	}
	.recent-link.current .recent-title {
		color: var(--accent);
	}
	.recent-title {
		font-size: 0.82em;
		color: var(--text);
		line-height: 1.3;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}
	.recent-date {
		font-size: 0.73em;
		color: var(--text-muted);
	}

	/* Tags link */
	.tags-link {
		display: block;
		padding: 0.6em 0.75em;
		border-radius: 8px;
		border: 1px solid var(--border);
		font-size: 0.85em;
		color: var(--text-muted);
		text-decoration: none;
		text-align: center;
		transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
		white-space: nowrap;
	}
	.tags-link:hover,
	.tags-link.active {
		color: var(--accent);
		border-color: var(--accent);
		background-color: var(--accent-dim);
		text-decoration: none;
	}

	/* Toggle button */
	.toggle-btn {
		flex-shrink: 0;
		width: 20px;
		padding: 0;
		margin-left: 4px;
		background: transparent;
		border: none;
		color: var(--text-muted);
		font-size: 1.1em;
		cursor: pointer;
		display: flex;
		align-items: flex-start;
		padding-top: 2px;
		transition: color 0.15s ease;
		line-height: 1;
		user-select: none;
	}
	.toggle-btn:hover {
		color: var(--accent);
	}

	@media (max-width: 768px) {
		.sidebar-container {
			display: none;
		}
	}
</style>
