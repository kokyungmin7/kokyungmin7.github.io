---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
	currentCategory?: string;
}

const { currentCategory } = Astro.props;

const currentPath = Astro.url.pathname;

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categoryMap = new Map<string, number>();
for (const post of allPosts) {
	const cat = post.data.category ?? '일반';
	categoryMap.set(cat, (categoryMap.get(cat) ?? 0) + 1);
}
const categories = [
	{ name: '전체', count: allPosts.length },
	...Array.from(categoryMap.entries()).map(([name, count]) => ({ name, count })),
];

const recentPosts = allPosts.slice(0, 5);
---

<div class="sidebar-container" id="sidebar-container">
	<!-- 버튼: 항상 상단 왼쪽에 고정 -->
	<button class="toggle-btn" id="sidebar-toggle" aria-label="사이드바 접기/펼치기">
		<div class="btn-icon">
			<span class="line line-1"></span>
			<span class="line line-2"></span>
		</div>
	</button>

	<!-- 좌우로 접히는 콘텐츠 패널 -->
	<div class="sidebar-panel" id="sidebar-panel">
		<!-- Categories -->
		<div class="sidebar-section sidebar-section--categories">
			<h3 class="sidebar-title">카테고리</h3>
			<ul class="category-list">
				{categories.map((cat) => (
					<li>
						<a
							href="/blog"
							class:list={[
								'category-link',
								{
									active: cat.name === (currentCategory ?? '전체') && currentPath.startsWith('/blog'),
								},
							]}
						>
							<span class="category-name">{cat.name}</span>
							<span class="category-count">{cat.count}</span>
						</a>
					</li>
				))}
			</ul>
		</div>

		<!-- Recent Posts -->
		<div class="sidebar-section sidebar-section--recent">
			<h3 class="sidebar-title">최신 글</h3>
			<ul class="recent-list">
				{recentPosts.map((post) => (
					<li>
						<a
							href={`/blog/${post.id}/`}
							class:list={['recent-link', { active: currentPath === `/blog/${post.id}/` }]}
						>
							<span class="recent-title">{post.data.title}</span>
							<span class="recent-date"><FormattedDate date={post.data.pubDate} /></span>
						</a>
					</li>
				))}
			</ul>
		</div>

		<!-- Tags link -->
		<a
			href="/tags"
			class:list={['tags-link', 'hover-underline-link', { active: currentPath.startsWith('/tags') }]}
		>
			# 태그 보기
		</a>
	</div>
</div>

<script>
	const container = document.getElementById('sidebar-container') as HTMLElement;
	const toggleBtn = document.getElementById('sidebar-toggle') as HTMLButtonElement;

	function setCollapsed(collapsed: boolean, animate = true) {
		if (!animate) container.classList.add('no-transition');
		if (collapsed) {
			container.classList.add('collapsed');
			document.documentElement.classList.add('sidebar-collapsed');
		} else {
			container.classList.remove('collapsed');
			document.documentElement.classList.remove('sidebar-collapsed');
		}
		if (!animate) {
			container.getBoundingClientRect();
			container.classList.remove('no-transition');
		}
		localStorage.setItem('sidebar-collapsed', String(collapsed));
	}

	// Restore state without animation to avoid flash
	const saved = localStorage.getItem('sidebar-collapsed');
	if (saved === 'true') setCollapsed(true, false);

	toggleBtn.addEventListener('click', () => {
		setCollapsed(!container.classList.contains('collapsed'));
	});
</script>

<style>
	.sidebar-container {
		display: flex;
		flex-direction: row;
		align-items: flex-start;
		flex-shrink: 0;
		position: sticky;
		top: 80px;
		align-self: flex-start;
		max-height: calc(100vh - 100px);
		margin-right: 6rem;
		transition: margin-right 0.3s ease;
	}

	.sidebar-container.collapsed,
	:global(html.sidebar-collapsed) .sidebar-container {
		margin-right: 3rem;
	}

	.sidebar-container.no-transition,
	.sidebar-container.no-transition .sidebar-panel,
	.sidebar-container.no-transition .toggle-btn .line {
		transition: none !important;
	}

	/* 버튼: 항상 상단 왼쪽 */
	.toggle-btn {
		flex-shrink: 0;
		align-self: flex-start;
		background: transparent;
		border: none;
		cursor: pointer;
		padding: 0.25em;
		margin-right: 0.5rem;
		outline: none;
		user-select: none;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.btn-icon {
		position: relative;
		width: 1.3em;
		height: 0.75em;
	}

	.line {
		display: block;
		position: absolute;
		width: 100%;
		top: 50%;
		background: var(--text-muted);
		height: 0.14em;
		border-radius: 10em;
		transition: transform 0.3s ease, background 0.15s ease;
	}

	.toggle-btn:hover .line {
		background: var(--accent);
	}

	/* 기본(펼침): X 아이콘 */
	.toggle-btn .line-1 {
		transform: translateY(-50%) rotate(45deg);
	}

	.toggle-btn .line-2 {
		transform: translateY(-50%) rotate(-45deg);
	}

	/* 접힌 상태: 햄버거 아이콘 */
	.sidebar-container.collapsed .toggle-btn .line-1,
	:global(html.sidebar-collapsed) .toggle-btn .line-1 {
		transform: translateY(calc(-50% - 4px)) rotate(0deg);
	}

	.sidebar-container.collapsed .toggle-btn .line-2,
	:global(html.sidebar-collapsed) .toggle-btn .line-2 {
		transform: translateY(calc(-50% + 4px)) rotate(0deg);
	}

	/* 좌우로 접히는 패널 */
	.sidebar-panel {
		width: 260px;
		max-height: calc(100vh - 100px);
		overflow-y: auto;
		overflow-x: hidden;
		transition: width 0.3s ease, opacity 0.2s ease;
		scrollbar-width: thin;
		scrollbar-color: var(--border) transparent;
	}

	.sidebar-container.collapsed .sidebar-panel,
	:global(html.sidebar-collapsed) .sidebar-panel {
		width: 0;
		opacity: 0;
		pointer-events: none;
		transition: width 0.3s ease, opacity 0.15s ease;
	}

	/* Sidebar sections — 헤더 nav pill과 동일한 글래스 카드 */
	.sidebar-section {
		background: var(--glass-bg);
		border: 1px solid var(--glass-border);
		border-radius: 1rem;
		padding: 1.25rem;
		margin-bottom: 0.9rem;
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		box-shadow: var(--glass-shadow);
	}

	.sidebar-title {
		font-size: 0.82em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-muted);
		margin: 0 0 0.9rem 0;
	}

	/* 목차(.toc-title)와 동일한 섹션 헤더 */
	.sidebar-section--categories .sidebar-title,
	.sidebar-section--recent .sidebar-title {
		color: var(--text-muted);
		margin: 0 0 0.9rem 0;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	/* Category list — 목차(.toc-item)와 동일 패턴 */
	.category-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.category-link {
		display: flex;
		justify-content: space-between;
		align-items: center;
		width: 100%;
		box-sizing: border-box;
		padding: 0.4em 0.6em;
		border-radius: 5px;
		text-decoration: none;
		font-size: 0.92em;
		line-height: 1.4;
		color: var(--text-muted);
		border-left: 2px solid transparent;
		transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
	}
	.category-link:hover {
		color: var(--text);
		background-color: var(--sidebar-list-hover-bg);
		text-decoration: none;
	}
	.category-link.active {
		color: var(--sidebar-list-active-color);
		border-left-color: var(--sidebar-list-indicator);
		background-color: var(--sidebar-list-active-bg);
		font-weight: 600;
	}

	.category-count {
		font-size: 0.8em;
		background: color-mix(in srgb, var(--text-muted) 20%, transparent);
		color: var(--text-muted);
		border-radius: 10px;
		padding: 0 0.45em;
		line-height: 1.5;
		flex-shrink: 0;
	}
	.category-link.active .category-count {
		color: var(--sidebar-list-active-color);
	}

	/* Recent posts — 카테고리·목차와 동일 패턴 */
	.recent-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.recent-link {
		display: flex;
		flex-direction: column;
		gap: 0.15em;
		width: 100%;
		box-sizing: border-box;
		padding: 0.4em 0.6em;
		border-radius: 5px;
		text-decoration: none;
		line-height: 1.4;
		border-left: 2px solid transparent;
		transition: color 0.15s ease, background-color 0.15s ease, border-color 0.15s ease;
	}
	.recent-link:hover {
		background-color: var(--sidebar-list-hover-bg);
		text-decoration: none;
	}
	.recent-link:hover .recent-title {
		color: var(--text);
	}
	.recent-link.active {
		border-left-color: var(--sidebar-list-indicator);
		background-color: var(--sidebar-list-active-bg);
	}
	.recent-link.active .recent-title {
		color: var(--sidebar-list-active-color);
		font-weight: 600;
	}
	.recent-title {
		font-size: 0.92em;
		color: var(--text-muted);
		line-height: 1.3;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
		overflow: hidden;
		transition: color 0.15s ease;
	}
	.recent-date {
		font-size: 0.8em;
		color: var(--text-muted);
	}

	/* Tags link */
	.tags-link.hover-underline-link {
		padding-bottom: 0.65em;
	}

	.tags-link {
		display: block;
		padding: 0.6em 0.75em 0.65em;
		border-radius: 1rem;
		border: 1px solid var(--glass-border);
		background: var(--glass-bg);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		box-shadow: var(--glass-shadow);
		font-size: 0.85em;
		color: var(--text-muted);
		text-decoration: none;
		text-align: center;
		transition: color 0.15s ease, border-color 0.15s ease, background-color 0.15s ease;
		white-space: nowrap;
	}
	.tags-link:hover,
	.tags-link.active {
		color: var(--text);
		border-color: var(--border);
		background-color: var(--glass-bg);
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.sidebar-container {
			display: none;
		}
	}
</style>
