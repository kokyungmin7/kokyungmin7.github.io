---
import {
	PROJECT_STATUS_CLASS,
	PROJECT_STATUS_LABEL,
	type ProjectEntry,
} from '../data/projects';

interface Props {
	project: ProjectEntry;
}

const { project } = Astro.props;
---

<article class="project-card card">
	<div class="card-header">
		<div class="card-badges">
			<span class:list={['status-badge', PROJECT_STATUS_CLASS[project.data.status]]}>
				{PROJECT_STATUS_LABEL[project.data.status]}
			</span>
			{project.data.category && <span class="category-badge">{project.data.category}</span>}
		</div>
		<div class="card-links">
			{project.data.links?.github && (
				<a
					href={project.data.links.github}
					target="_blank"
					rel="noopener"
					class="icon-link"
					aria-label="GitHub"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 16 16" fill="currentColor">
						<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
					</svg>
				</a>
			)}
			{project.data.links?.demo && (
				<a
					href={project.data.links.demo}
					target="_blank"
					rel="noopener"
					class="icon-link"
					aria-label="Live Demo"
				>
					<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
						<polyline points="15 3 21 3 21 9" />
						<line x1="10" y1="14" x2="21" y2="3" />
					</svg>
				</a>
			)}
		</div>
	</div>

	<h2 class="project-title">{project.data.title}</h2>
	<p class="project-desc">{project.data.description}</p>

	{project.data.metrics && project.data.metrics.length > 0 && (
		<div class="metrics-grid">
			{project.data.metrics.map((metric) => (
				<div class="metric-item">
					<span class="metric-value">{metric.value}</span>
					<span class="metric-label">{metric.label}</span>
				</div>
			))}
		</div>
	)}

	{project.data.highlights && project.data.highlights.length > 0 && (
		<ul class="highlights-list">
			{project.data.highlights.map((highlight) => (
				<li>{highlight}</li>
			))}
		</ul>
	)}

	{project.data.techStack.length > 0 && (
		<div class="tech-stack">
			{project.data.techStack.map((tech) => (
				<span class="tech-tag">{tech}</span>
			))}
		</div>
	)}
</article>

<style>
	.project-card {
		display: flex;
		flex-direction: column;
		gap: 0;
		border-radius: 12px;
	}

	.project-card:hover {
		border-color: var(--accent);
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 0.9rem;
	}

	.card-badges {
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
	}

	.card-links {
		display: flex;
		gap: 0.4rem;
	}

	.status-badge,
	.category-badge {
		font-size: 0.75em;
		font-weight: 600;
		padding: 0.2em 0.65em;
		border-radius: 20px;
		letter-spacing: 0.02em;
	}

	.status-active {
		background: rgba(52, 211, 153, 0.15);
		color: #34d399;
		border: 1px solid rgba(52, 211, 153, 0.3);
	}

	.status-wip {
		background: rgba(251, 191, 36, 0.15);
		color: #fbbf24;
		border: 1px solid rgba(251, 191, 36, 0.3);
	}

	.status-archived {
		background: rgba(156, 163, 175, 0.15);
		color: #9ca3af;
		border: 1px solid rgba(156, 163, 175, 0.3);
	}

	.category-badge {
		background: var(--accent-dim);
		color: var(--accent);
		border: 1px solid color-mix(in srgb, var(--accent) 25%, transparent);
	}

	.icon-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 30px;
		height: 30px;
		border-radius: 6px;
		color: var(--text-muted);
		text-decoration: none;
		transition: color 0.15s ease, background-color 0.15s ease;
	}

	.icon-link:hover {
		color: var(--accent);
		background-color: var(--accent-dim);
		text-decoration: none;
	}

	.project-title {
		font-size: 1.2em;
		font-weight: 700;
		color: var(--text);
		margin: 0 0 0.45rem 0;
		line-height: 1.3;
	}

	.project-desc {
		font-size: 0.9em;
		color: var(--text-muted);
		margin: 0 0 1.25rem 0;
		line-height: 1.5;
	}

	.metrics-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
		gap: 0.6rem;
		margin-bottom: 1.25rem;
	}

	.metric-item {
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 8px;
		padding: 0.7rem 0.8rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
		text-align: center;
	}

	.metric-value {
		font-size: 1.25em;
		font-weight: 700;
		color: var(--accent);
		line-height: 1;
	}

	.metric-label {
		font-size: 0.72em;
		color: var(--text-muted);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.highlights-list {
		margin: 0 0 1.25rem 0;
		padding-left: 1.1rem;
		color: var(--text-muted);
	}

	.highlights-list li + li {
		margin-top: 0.4rem;
	}

	.tech-stack {
		display: flex;
		flex-wrap: wrap;
		gap: 0.45rem;
		margin-top: auto;
	}

	.tech-tag {
		font-size: 0.78em;
		padding: 0.28em 0.65em;
		border-radius: 999px;
		background: color-mix(in srgb, var(--text) 6%, transparent);
		border: 1px solid var(--border);
		color: var(--text);
	}
</style>
