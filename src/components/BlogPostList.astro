---
import FormattedDate from './FormattedDate.astro';
import type { BlogPostEntry } from '../data/blog';

interface Props {
	posts: BlogPostEntry[];
	variant?: 'home' | 'list';
}

const { posts, variant = 'list' } = Astro.props;
const isHomeVariant = variant === 'home';
---

<ul class="post-list">
	{posts.map((post) => (
		<li>
			<a href={`/blog/${post.id}/`} class:list={['post-card', { 'post-card--home': isHomeVariant }]}>
				{isHomeVariant ? (
					<div class="post-meta post-meta--leading">
						<span class="post-date">
							<FormattedDate date={post.data.pubDate} />
						</span>
					</div>
				) : null}
				<div class="post-body">
					<h2 class:list={['post-title', { 'post-title--home': isHomeVariant }]}>
						{post.data.title}
					</h2>
					{post.data.description && <p class="post-desc">{post.data.description}</p>}
				</div>
				{!isHomeVariant ? (
					<div class="post-meta post-meta--trailing">
						<span class="post-date">
							<FormattedDate date={post.data.pubDate} />
						</span>
					</div>
				) : null}
			</a>
		</li>
	))}
</ul>

<style>
	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.post-card {
		display: flex;
		align-items: stretch;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 10px;
		text-decoration: none;
		overflow: hidden;
		transition: border-color 0.2s ease, background-color 0.2s ease;
	}

	.post-card:hover {
		border-color: var(--accent);
		background-color: var(--accent-dim);
		text-decoration: none;
	}

	.post-card--home .post-meta--leading {
		border-right: 1px solid var(--border);
		padding: 1.2rem 1.25rem;
	}

	.post-body {
		flex: 1;
		min-width: 0;
		padding: 1.4rem 1.6rem;
	}

	.post-card--home .post-body {
		padding: 1.2rem 1.4rem;
	}

	.post-title {
		font-size: 1.2em;
		font-weight: 600;
		color: var(--text);
		margin: 0 0 0.4rem 0;
		line-height: 1.35;
	}

	.post-title--home {
		font-size: 1em;
		margin-bottom: 0.3rem;
		line-height: 1.3;
	}

	.post-desc {
		font-size: 0.875em;
		color: var(--text-muted);
		margin: 0;
		overflow: hidden;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
	}

	.post-meta {
		flex-shrink: 0;
		display: flex;
		align-items: center;
	}

	.post-meta--trailing {
		padding: 1.4rem;
		border-left: 1px solid var(--border);
	}

	.post-date {
		font-size: 0.82em;
		color: var(--text-muted);
		white-space: nowrap;
	}

	@media (max-width: 600px) {
		.post-card {
			flex-direction: column;
		}

		.post-card--home .post-meta--leading {
			border-right: none;
			border-bottom: 1px solid var(--border);
			padding: 0.75rem 1.25rem;
		}

		.post-meta--trailing {
			border-left: none;
			border-top: 1px solid var(--border);
			padding: 0.75rem 1.4rem;
		}
	}
</style>
