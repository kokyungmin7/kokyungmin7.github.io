---
import { Image } from 'astro:assets';
import FormattedDate from './FormattedDate.astro';
import { getBlogPostPath, type BlogPostEntry } from '../data/blog';

interface Props {
	posts: BlogPostEntry[];
	variant?: 'home' | 'list';
}

const { posts, variant = 'list' } = Astro.props;
const isHomeVariant = variant === 'home';
---

{isHomeVariant ? (
	<ul class="post-list--home">
		{posts.map((post) => (
			<li>
				<a href={getBlogPostPath(post.id)} class="post-card--home">
					<div class="post-meta--leading">
						<span class="post-date">
							<FormattedDate date={post.data.pubDate} />
						</span>
					</div>
					<div class="post-body--home">
						<h2 class="post-title--home">{post.data.title}</h2>
						{post.data.description && <p class="post-desc--home">{post.data.description}</p>}
					</div>
				</a>
			</li>
		))}
	</ul>
) : (
	<ul class="post-list">
		{posts.map((post, index) => (
			<li class="post-item">
				<a href={getBlogPostPath(post.id)} class="post-row">
					<span class="post-num">
						{String(index + 1).padStart(2, '0')}<span class="post-dot">.</span>
					</span>
					<div class="post-thumb">
						{post.data.heroImage ? (
							<Image
								src={post.data.heroImage}
								alt={post.data.title}
								width={480}
								height={360}
							/>
						) : (
							<div class="post-thumb-placeholder" aria-hidden="true"></div>
						)}
					</div>
					<div class="post-detail">
						<h2 class="post-title">{post.data.title}</h2>
						{post.data.description && (
							<p class="post-desc">{post.data.description}</p>
						)}
						{post.data.tags && post.data.tags.length > 0 && (
							<div class="post-tags">
								{post.data.tags.map((tag) => (
									<span class="post-tag">{tag}</span>
								))}
							</div>
						)}
					</div>
				</a>
			</li>
		))}
	</ul>
)}

<style>
	/* ── List (Nakula style — always expanded) ───── */

	.post-list {
		list-style: none;
		margin: 0;
		padding: 0;
		border-bottom: 1px solid var(--border);
	}

	.post-item {
		border-top: 1px solid var(--border);
	}

	.post-row {
		display: grid;
		grid-template-columns: 120px 0.87fr 3fr;
		align-items: center;
		gap: 3rem;
		padding: 2rem 0.5rem;
		text-decoration: none;
		cursor: pointer;
	}

	/* Number */
	.post-num {
		font-size: 2.75rem;
		font-weight: 700;
		color: rgba(255, 255, 255, 0.2);
		letter-spacing: -0.03em;
		line-height: 1;
		align-self: center;
		white-space: nowrap;
	}

	:global([data-theme='light']) .post-num {
		color: rgba(0, 0, 0, 0.15);
	}

	.post-dot {
		color: var(--accent);
	}

	/* Thumbnail */
	.post-thumb {
		border-radius: 10px;
		overflow: hidden;
		width: 100%;
		aspect-ratio: 1 / 1;
	}

	.post-thumb img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.post-thumb-placeholder {
		width: 100%;
		height: 100%;
		background: var(--bg-card);
		border: 1px solid var(--border);
	}

	/* Detail */
	.post-detail {
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 0.9rem;
		min-width: 0;
	}

	.post-title {
		font-size: 2.25rem;
		font-weight: 700;
		color: var(--text);
		margin: 0;
		line-height: 1.2;
		overflow: hidden;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
	}

	.post-desc {
		font-size: 0.95rem;
		color: var(--text-muted);
		margin: 0;
		line-height: 1.65;
		overflow: hidden;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
	}

	.post-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		margin-top: 0.25rem;
	}

	.post-tag {
		font-size: 0.78rem;
		color: var(--text-muted);
		border: 1px solid var(--border);
		border-radius: 20px;
		padding: 0.25rem 0.85rem;
		white-space: nowrap;
	}

	/* ── Responsive ──────────────────────────────── */

	@media (max-width: 960px) {
		.post-row {
			grid-template-columns: 80px 0.57fr 1.4fr;
			gap: 2rem;
			padding: 1.75rem 0.25rem;
		}


		.post-num {
			font-size: 2rem;
		}

		.post-title {
			font-size: 1.75rem;
		}
	}

	@media (max-width: 640px) {
		.post-row {
			grid-template-columns: 1fr;
			height: auto;
			gap: 1rem;
			padding: 1.75rem 0;
		}

		.post-num {
			font-size: 1.5rem;
		}

		.post-thumb {
			aspect-ratio: 16 / 9;
		}

		.post-title {
			font-size: 1.4rem;
		}
	}

	/* ── Home variant ────────────────────────────── */

	.post-list--home {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.75rem;
	}

	.post-card--home {
		display: flex;
		align-items: stretch;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 10px;
		text-decoration: none;
		overflow: hidden;
		transition: border-color 0.2s ease, background-color 0.2s ease;
	}

	.post-card--home:hover {
		border-color: var(--accent);
		background-color: var(--accent-dim);
	}

	.post-meta--leading {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		border-right: 1px solid var(--border);
		padding: 1.2rem 1.25rem;
	}

	.post-date {
		font-size: 0.82em;
		color: var(--text-muted);
		white-space: nowrap;
	}

	.post-body--home {
		flex: 1;
		min-width: 0;
		padding: 1.2rem 1.4rem;
	}

	.post-title--home {
		font-size: 1em;
		font-weight: 600;
		color: var(--text);
		margin: 0 0 0.3rem 0;
		line-height: 1.3;
	}

	.post-desc--home {
		font-size: 0.875em;
		color: var(--text-muted);
		margin: 0;
		overflow: hidden;
		display: -webkit-box;
		-webkit-line-clamp: 2;
		-webkit-box-orient: vertical;
	}

	@media (max-width: 600px) {
		.post-card--home {
			flex-direction: column;
		}

		.post-meta--leading {
			border-right: none;
			border-bottom: 1px solid var(--border);
			padding: 0.75rem 1.25rem;
		}
	}
</style>
