---
import { SITE_AUTHOR } from '../consts';
---

<div class="profile-card">
	<div class="profile-avatar">
		<span class="avatar-initials">{SITE_AUTHOR.initials}</span>
	</div>
	<div class="profile-info">
		<h1 class="profile-name">{SITE_AUTHOR.name}</h1>
		<p class="profile-role">{SITE_AUTHOR.role}</p>
		<div class="profile-links">
			<a href={SITE_AUTHOR.github.url} target="_blank" rel="noopener" class="profile-link">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z" />
				</svg>
				{SITE_AUTHOR.github.label}
			</a>
			<a href={`mailto:${SITE_AUTHOR.email}`} class="profile-link">
				<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<rect x="2" y="4" width="20" height="16" rx="2"></rect>
					<path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path>
				</svg>
				{SITE_AUTHOR.email}
			</a>
		</div>
	</div>
</div>

<style>
	.profile-card {
		display: flex;
		align-items: center;
		gap: 1.5rem;
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		padding: 2rem;
		margin-bottom: 2.5rem;
	}

	.profile-avatar {
		flex-shrink: 0;
		width: 72px;
		height: 72px;
		border-radius: 50%;
		background: var(--accent-dim);
		border: 2px solid var(--accent);
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.avatar-initials {
		font-size: 1.8em;
		font-weight: 700;
		color: var(--accent);
	}

	.profile-info {
		flex: 1;
		min-width: 0;
	}

	.profile-name {
		font-size: 1.6em;
		font-weight: 700;
		margin: 0 0 0.2rem 0;
		color: var(--text);
	}

	.profile-role {
		font-size: 0.95em;
		color: var(--text-muted);
		margin: 0 0 0.9rem 0;
	}

	.profile-links {
		display: flex;
		flex-wrap: wrap;
		gap: 0.75rem;
	}

	.profile-link {
		display: inline-flex;
		align-items: center;
		gap: 0.4em;
		font-size: 0.875em;
		color: var(--text-muted);
		padding: 0.3em 0.7em;
		border: 1px solid var(--border);
		border-radius: 6px;
		text-decoration: none;
		transition: color 0.2s ease, border-color 0.2s ease, background-color 0.2s ease;
	}

	.profile-link:hover {
		color: var(--accent);
		border-color: var(--accent);
		background-color: var(--accent-dim);
		text-decoration: none;
	}

	@media (max-width: 600px) {
		.profile-card {
			flex-direction: column;
			text-align: center;
			padding: 1.5rem;
		}

		.profile-links {
			justify-content: center;
		}
	}
</style>
