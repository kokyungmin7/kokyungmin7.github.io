---
import ShinyText from './ShinyText';
---

<section class="coming-soon" aria-label="Coming Soon">
	<div class="coming-soon__text">
		<h1 class="coming-soon__heading">
			<ShinyText text="Coming Soon" speed={2} color="var(--coming-soon-text)" shineColor="var(--coming-soon-shine)" client:load />
		</h1>
	</div>
</section>

<style>
	.coming-soon {
		--coming-soon-text: #b5b5b5;
		--coming-soon-shine: #ffffff;
		display: grid;
		place-items: center;
		min-height: calc(100vh - 5rem);
		padding: 2rem;
	}

	.coming-soon__text {
		width: min(900px, 100%);
		text-align: center;
	}

	.coming-soon__heading {
		position: relative;
		display: inline-block;
		margin: 0;
		font-family: Helvetica, Arial, sans-serif;
		font-size: 7rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
	}

	@media (max-width: 720px) {
		.coming-soon {
			min-height: calc(100vh - 3rem);
			padding: 1rem;
		}

		.coming-soon__heading {
			font-size: 3.5rem;
		}
	}
</style>
