---
import type { BlogSearchEntry } from '../data/blog';

interface Props {
	searchEntries: BlogSearchEntry[];
}

const { searchEntries } = Astro.props;
---

<div class="search-overlay" id="search-overlay" aria-hidden="true">
	<div class="search-modal" role="dialog" aria-label="포스트 검색">
		<div class="search-input-wrap">
			<svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
				<circle cx="11" cy="11" r="8" /><path d="m21 21-4.35-4.35" />
			</svg>
			<input
				type="text"
				id="search-input"
				placeholder="포스트 검색..."
				autocomplete="off"
				spellcheck="false"
			/>
			<kbd class="search-esc-hint">ESC</kbd>
		</div>
		<ul class="search-results" id="search-results" role="listbox"></ul>
		<p class="search-message" id="search-hint">검색어를 입력하세요</p>
		<p class="search-message" id="search-empty" style="display:none">결과가 없습니다</p>
	</div>
</div>

<script define:vars={{ searchEntries }}>
	const overlay = document.getElementById('search-overlay');
	const input = document.getElementById('search-input');
	const results = document.getElementById('search-results');
	const hint = document.getElementById('search-hint');
	const empty = document.getElementById('search-empty');

	function isTypingTarget(element) {
		return (
			element instanceof HTMLElement &&
			(element.tagName === 'INPUT' ||
				element.tagName === 'TEXTAREA' ||
				element.isContentEditable)
		);
	}

	function openSearch() {
		if (!overlay || !input || !results || !hint || !empty) return;

		overlay.style.display = 'flex';
		overlay.setAttribute('aria-hidden', 'false');
		input.value = '';
		results.innerHTML = '';
		hint.style.display = 'block';
		empty.style.display = 'none';
		requestAnimationFrame(() => input.focus());
	}

	function closeSearch() {
		if (!overlay) return;

		overlay.style.display = 'none';
		overlay.setAttribute('aria-hidden', 'true');
	}

	function highlightMatchedText(text, query) {
		if (!query) return text;

		const matchedIndex = text.toLowerCase().indexOf(query.toLowerCase());
		if (matchedIndex === -1) return text;

		return (
			text.slice(0, matchedIndex) +
			'<mark>' +
			text.slice(matchedIndex, matchedIndex + query.length) +
			'</mark>' +
			text.slice(matchedIndex + query.length)
		);
	}

	function renderResults(filteredEntries, query) {
		if (!results) return;

		results.innerHTML = '';
		filteredEntries.forEach((post) => {
			const listItem = document.createElement('li');
			listItem.setAttribute('role', 'option');

			const link = document.createElement('a');
			link.href = `/blog/${post.id}/`;
			link.innerHTML = `
				<span class="result-title">${highlightMatchedText(post.title, query)}</span>
				${post.description ? `<span class="result-desc">${highlightMatchedText(post.description, query)}</span>` : ''}
				${post.category ? `<span class="result-cat">${post.category}</span>` : ''}
			`;
			link.addEventListener('click', closeSearch);

			listItem.appendChild(link);
			results.appendChild(listItem);
		});
	}

	document.addEventListener('keydown', (event) => {
		if (event.key === '/' && !isTypingTarget(event.target)) {
			event.preventDefault();
			openSearch();
		}

		if (event.key === 'Escape' && overlay instanceof HTMLElement && overlay.style.display !== 'none') {
			closeSearch();
		}
	});

	overlay?.addEventListener('click', (event) => {
		if (event.target === overlay) closeSearch();
	});

	input?.addEventListener('input', () => {
		if (!results || !hint || !empty || !input) return;

		const query = input.value.trim();
		results.innerHTML = '';

		if (!query) {
			hint.style.display = 'block';
			empty.style.display = 'none';
			return;
		}

		hint.style.display = 'none';

		const normalizedQuery = query.toLowerCase();
		const filteredEntries = searchEntries.filter(
			(post) =>
				post.title.toLowerCase().includes(normalizedQuery) ||
				post.description.toLowerCase().includes(normalizedQuery) ||
				post.category.toLowerCase().includes(normalizedQuery),
		);

		if (filteredEntries.length === 0) {
			empty.style.display = 'block';
			return;
		}

		empty.style.display = 'none';
		renderResults(filteredEntries, query);
	});
</script>

<style>
	.search-overlay {
		display: none;
		position: fixed;
		inset: 0;
		background: rgba(0, 0, 0, 0.55);
		z-index: 500;
		align-items: flex-start;
		justify-content: center;
		padding-top: 80px;
		backdrop-filter: blur(3px);
	}

	.search-modal {
		background: var(--bg-card);
		border: 1px solid var(--border);
		border-radius: 12px;
		width: 100%;
		max-width: 580px;
		max-height: 70vh;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		box-shadow: var(--box-shadow);
		margin: 0 1rem;
	}

	.search-input-wrap {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		padding: 0.875rem 1.25rem;
		border-bottom: 1px solid var(--border);
		flex-shrink: 0;
	}

	.search-icon {
		flex-shrink: 0;
		color: var(--text-muted);
	}

	#search-input {
		flex: 1;
		border: none;
		background: transparent;
		color: var(--text);
		font-size: 1em;
		font-family: inherit;
		outline: none;
		min-width: 0;
	}
	#search-input::placeholder {
		color: var(--text-muted);
	}

	.search-esc-hint {
		flex-shrink: 0;
		font-size: 0.75em;
		color: var(--text-muted);
		background: var(--bg);
		border: 1px solid var(--border);
		border-radius: 4px;
		padding: 0.15em 0.5em;
		font-family: inherit;
		cursor: default;
	}

	.search-results {
		list-style: none;
		margin: 0;
		padding: 0.5rem;
		overflow-y: auto;
		flex: 1;
	}

	.search-results li a {
		display: flex;
		flex-direction: column;
		gap: 0.2em;
		padding: 0.7rem 0.75rem;
		border-radius: 8px;
		text-decoration: none;
		transition: background-color 0.15s ease;
	}
	.search-results li a:hover {
		background-color: var(--accent-dim);
		text-decoration: none;
	}

	.result-title {
		font-size: 0.95em;
		font-weight: 600;
		color: var(--text);
		line-height: 1.3;
	}
	.result-desc {
		font-size: 0.82em;
		color: var(--text-muted);
		overflow: hidden;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
	}
	.result-cat {
		font-size: 0.73em;
		color: var(--accent);
		background: var(--accent-dim);
		padding: 0.1em 0.5em;
		border-radius: 4px;
		width: fit-content;
		margin-top: 0.1em;
	}

	:global(.search-results mark) {
		background: var(--accent-dim);
		color: var(--accent);
		border-radius: 2px;
		font-style: normal;
	}

	.search-message {
		padding: 0.9rem 1.25rem 1.1rem;
		margin: 0;
		color: var(--text-muted);
		font-size: 0.88em;
		border-top: 1px solid var(--border);
	}
</style>
