---
import FormattedDate from '../FormattedDate.astro';
import {
	getBlogCategoryPath,
	getBlogPostPath,
	type BlogCategoryTree,
	type BlogPostEntry,
} from '../../data/blog';

interface Props {
	categoryTree: BlogCategoryTree[];
	recentPosts: BlogPostEntry[];
	currentPath: string;
	currentCategory?: string;
	currentSubcategory?: string;
	isBlogSection: boolean;
}

const { categoryTree, recentPosts, currentPath, currentCategory, currentSubcategory, isBlogSection } = Astro.props;
---

<div class:list={['blog-content', { 'blog-content--visible': isBlogSection }]}>
	<div class="blog-section">
		<h3 class="blog-section-title">Category</h3>

		<!-- 부모 카테고리 트리 -->
		{categoryTree.map((parent) => (
			<div class="category-row">
				<input
					type="checkbox"
					id={`cat-${parent.name}`}
					class="category-toggle"
					checked={parent.name === currentCategory}
				/>
				<label for={`cat-${parent.name}`} class="category-header sidebar-nav-item">
					<svg class="folder-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
						<path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/>
					</svg>
					<span class="entry-name">{parent.name}</span>
					<span class="entry-count">({parent.count})</span>
					<div class="chevron-container">
						<svg class="chevron-down" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
							<polyline points="6 9 12 15 18 9"/>
						</svg>
					</div>
				</label>

				{parent.subcategories.length > 0 && (
					<ul class="subcategory-list">
						{parent.subcategories.map((sub) => (
							<li>
								<a
									href={getBlogCategoryPath(parent.name, sub.name)}
									class:list={[
										'sidebar-nav-item',
										'subcategory-link',
										{ active: sub.name === currentSubcategory && parent.name === currentCategory },
									]}
								>
									<span class="entry-name">{sub.name}</span>
									<span class="entry-count">({sub.count})</span>
								</a>
							</li>
						))}
					</ul>
				)}
			</div>
		))}
	</div>

	<div class="blog-section">
		<h3 class="blog-section-title">Recent Posts</h3>
		<ul class="recent-list">
			{recentPosts.map((post) => (
				<li>
					<a
						href={getBlogPostPath(post.id)}
						class:list={['sidebar-nav-item', 'recent-link', { active: currentPath === getBlogPostPath(post.id) }]}
					>
						<span class="recent-title">{post.data.title}</span>
						<span class="recent-date"><FormattedDate date={post.data.pubDate} /></span>
					</a>
				</li>
			))}
		</ul>
	</div>

	<a
		href="/tags"
		class:list={['tags-link', 'hover-underline-link', { active: currentPath.startsWith('/tags') }]}
	>
		# Tags
	</a>
</div>

<script>
	import { gsap } from 'gsap';

	const blogContent = document.querySelector('.blog-content') as HTMLElement | null;
	const sidebarItems = blogContent
		? blogContent.querySelectorAll<HTMLElement>(
			'.blog-section-title, .category-header, .subcategory-link, .recent-link, .tags-link',
		)
		: [];

	function animateSidebarItems() {
		if (!blogContent?.classList.contains('blog-content--visible') || sidebarItems.length === 0) return;

		gsap.set(sidebarItems, { opacity: 0, y: 30 });
		window.setTimeout(() => {
			gsap.fromTo(
				sidebarItems,
				{ opacity: 0, y: 30 },
				{ opacity: 1, y: 0, duration: 0.5, ease: 'power3.out', stagger: 0.025 },
			);
		}, 300);
	}

	window.addEventListener('sidebar:expanded', animateSidebarItems);

	if (blogContent?.classList.contains('blog-content--visible')) {
		const items = Array.from(blogContent.children) as HTMLElement[];

		// 블로그/태그 내부 이동이면 애니메이션 없이 즉시 표시
		const ref = document.referrer;
		let comingFromBlog = false;
		try {
			const refPath = ref ? new URL(ref).pathname : '';
			comingFromBlog = refPath.startsWith('/blog') || refPath.startsWith('/tags');
		} catch {}

		if (comingFromBlog) {
			gsap.set(items, { opacity: 1, y: 0 });
		} else {
			// 진입: 아래→위 stagger 슬라이드업
			gsap.fromTo(
				items,
				{ opacity: 0, y: 24 },
				{ opacity: 1, y: 0, duration: 0.6, ease: 'power3.out', stagger: 0.12, force3D: true },
			);
		}

		// 퇴장: 위로 사라지며 페이지 이동
		const navLinks = document.querySelectorAll<HTMLAnchorElement>('.site-nav-item');

		navLinks.forEach((link) => {
			link.addEventListener('click', (e) => {
				const href = link.getAttribute('href') ?? '';
				const leavingBlog = !href.startsWith('/blog') && !href.startsWith('/tags');

				if (leavingBlog) {
					e.preventDefault();
					gsap.to(items, {
						opacity: 0,
						y: -20,
						duration: 0.01,
						ease: 'power2.in',
						stagger: 0.06,
						onComplete: () => { window.location.href = href; },
					});
				}
			});
		});
	}
</script>

<style>
	/* ── 블로그 콘텐츠 ── */
	.blog-content {
		overflow: hidden;
		max-height: 0;
	}

	.blog-content--visible {
		max-height: 2000px;
	}

	/* 초기 숨김 — GSAP이 애니메이션 처리 */
	.blog-content > * {
		opacity: 0;
		transform: translateY(24px);
	}

	/* collapsed: 블로그 콘텐츠 숨김 */
	:global(html.sidebar-collapsed) .blog-content {
		display: none;
	}

	.blog-section {
		padding: 0.75rem 1.25rem;
		margin-bottom: 0.25rem;
	}

	.blog-section-title {
		font-size: 0.72rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--sidebar-muted);
		margin: 0 0 0.5rem 0;
		padding-bottom: 0.6rem;
		border-bottom: 1px solid var(--sidebar-divider);
	}

	/* ── 공통 엔트리 텍스트 ── */
	.entry-name {
		flex: 1;
		min-width: 0;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.entry-count {
		font-size: 0.8em;
		color: var(--sidebar-muted);
		margin-left: 0.3em;
		flex-shrink: 0;
	}

	/* ── 전체 링크 ── */
	.all-link {
		display: flex;
		align-items: center;
		width: 100%;
		box-sizing: border-box;
		margin-bottom: 0.1rem;
	}

	/* ── 카테고리 행 ── */
	.category-row {
		position: relative;
	}

	/* hidden checkbox */
	.category-toggle {
		position: absolute;
		opacity: 0;
		width: 0;
		height: 0;
	}

	/* ── 카테고리 헤더 (label) ── */
	.category-header {
		display: flex;
		align-items: center;
		width: 100%;
		box-sizing: border-box;
		cursor: pointer;
		gap: 0.4rem;
	}

	.folder-icon {
		flex-shrink: 0;
		color: var(--sidebar-icon-muted);
		transition: color 0.15s ease;
	}

	.category-header:hover .folder-icon {
		color: var(--sidebar-icon-hover);
	}

	/* ── Chevron ── */
	.chevron-container {
		position: relative;
		width: 16px;
		height: 16px;
		margin-left: auto;
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.chevron-down {
		position: absolute;
		color: var(--sidebar-muted);
		animation: keyframes-return 0.5s;
		transition: color 0.15s ease;
	}

	.category-header:hover .chevron-down {
		color: var(--sidebar-icon-hover);
	}

	.category-toggle:checked ~ .category-header .chevron-down {
		animation: keyframes-rotate 0.5s;
		transform: rotate(-180deg);
	}

	@keyframes keyframes-rotate {
		0% {
			transform: rotate(0deg);
			opacity: 0;
		}
		100% {
			transform: rotate(-180deg);
		}
	}

	@keyframes keyframes-return {
		0% {
			transform: rotate(-180deg);
			opacity: 0;
		}
		100% {
			transform: rotate(0deg);
		}
	}

	/* ── 서브카테고리 리스트 ── */
	.subcategory-list {
		list-style: none;
		margin: 0;
		padding: 0 0 0 1.75rem;
		max-height: 0;
		overflow: hidden;
		transition: max-height 0.3s ease;
	}

	.category-toggle:checked ~ .subcategory-list {
		max-height: 500px;
	}

	.subcategory-link {
		display: flex;
		align-items: center;
		width: 100%;
		box-sizing: border-box;
		font-size: 0.88em;
	}

	/* ── 다크 패널 위 sidebar-nav-item 색상 override ── */
	:global(.sidebar-panel) :global(.sidebar-nav-item) {
		color: var(--sidebar-nav-color);
		border-radius: 0.35rem;
	}

	:global(.sidebar-panel) :global(.sidebar-nav-item:hover) {
		color: var(--sidebar-nav-hover-color);
		background: var(--sidebar-nav-hover-bg);
	}

	:global(.sidebar-panel) :global(.sidebar-nav-item.active) {
		color: var(--sidebar-nav-active-color);
		background: var(--sidebar-nav-active-bg);
		border-left-color: var(--accent);
	}

	/* ── 최신 글 ── */
	.recent-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.1rem;
	}

	.recent-link {
		display: flex;
		flex-direction: column;
		gap: 0.15em;
		width: 100%;
		box-sizing: border-box;
	}

	.recent-title {
		font-size: 0.88em;
		line-height: 1.3;
		display: -webkit-box;
		-webkit-line-clamp: 1;
		-webkit-box-orient: vertical;
		overflow: hidden;
		transition: color 0.15s ease;
	}

	.recent-date {
		font-size: 0.78em;
		color: var(--sidebar-muted);
	}

	/* ── 태그 링크 ── */
	.tags-link {
		display: block;
		margin: 0 1.25rem 0.5rem;
		padding: 0.55em 0.75em 0.6em;
		border-radius: 0.5rem;
		font-size: 0.82em;
		color: var(--sidebar-nav-color);
		text-decoration: none;
		text-align: center;
		border: 1px solid var(--sidebar-divider);
		transition: color 0.15s ease, border-color 0.15s ease, background 0.15s ease;
		white-space: nowrap;
	}

	.tags-link:hover,
	.tags-link.active {
		color: var(--sidebar-nav-hover-color);
		border-color: var(--theme-toggle-ring);
		background: var(--sidebar-nav-hover-bg);
		text-decoration: none;
	}
</style>
