---
import BlogSearchOverlay from '../components/BlogSearchOverlay.astro';
import type { BlogSearchEntry } from '../data/blog';
import SiteLayout from './SiteLayout.astro';

interface Props {
	title: string;
	description: string;
	searchEntries: BlogSearchEntry[];
	mainClass?: string;
	currentCategory?: string;
	currentSubcategory?: string;
}

const { title, description, searchEntries, mainClass, currentCategory, currentSubcategory } = Astro.props;
---

<SiteLayout title={title} description={description} currentCategory={currentCategory} currentSubcategory={currentSubcategory}>
	<BlogSearchOverlay searchEntries={searchEntries} />
	<div class="page-wrapper">
		<main class:list={['page-main', mainClass]}>
			<slot />
		</main>
		<slot name="pageAside" />
	</div>
</SiteLayout>
