---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import SiteLayout from './SiteLayout.astro';

interface Props {
	title: string;
	description: string;
	heroImage?: ImageMetadata;
	eyebrow?: string;
	mainClass?: string;
}

const { title, description, heroImage, eyebrow, mainClass } = Astro.props;
---

<SiteLayout title={title} description={description}>
	<div class="content-shell">
		<main class:list={['content-main', mainClass]}>
			<article class="content-article">
				{heroImage && (
					<div class="hero-image">
						<Image width={1020} height={510} src={heroImage} alt="" />
					</div>
				)}
				<header class="page-header content-header">
					{eyebrow && <p class="page-eyebrow">{eyebrow}</p>}
					<h1>{title}</h1>
					{description && <p class="page-description">{description}</p>}
				</header>
				<div class="prose-content">
					<slot />
				</div>
			</article>
		</main>
	</div>
</SiteLayout>

<style>
	.content-shell {
		max-width: 1080px;
		margin: 0 auto;
		padding: 2.5em 1.5em;
	}

	.content-main {
		max-width: 860px;
		margin: 0 auto;
	}

	.content-article {
		width: 100%;
	}

	.content-header {
		margin-bottom: 2rem;
	}

	.hero-image {
		width: 100%;
		margin-bottom: 2rem;
	}

	.hero-image :global(img) {
		display: block;
		width: 100%;
		border-radius: 12px;
		border: 1px solid var(--border);
	}

	.page-eyebrow {
		font-size: 0.78em;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--text-muted);
		margin: 0 0 0.8rem 0;
	}

	.page-description {
		font-size: 1rem;
		color: var(--text-muted);
		margin: 0.75rem 0 0 0;
	}

	.prose-content :global(h2),
	.prose-content :global(h3),
	.prose-content :global(h4) {
		scroll-margin-top: 80px;
	}

	@media (max-width: 720px) {
		.content-shell {
			padding: 1.5em 1em;
		}
	}
</style>
