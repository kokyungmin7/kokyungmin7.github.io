---
import BaseHead from '../components/BaseHead.astro';
import BlogSidebar from '../components/BlogSidebar.astro';
import { getBlogDataset } from '../data/blog';

interface Props {
	title: string;
	description: string;
	currentCategory?: string;
	currentSubcategory?: string;
}

const { title, description, currentCategory, currentSubcategory } = Astro.props;
const { categoryTree, recentPosts } = await getBlogDataset();
---

<!doctype html>
<html lang="ko">
	<head>
		<BaseHead title={title} description={description} />
	</head>
	<body>
		<div class="site-layout">
			<BlogSidebar categoryTree={categoryTree} recentPosts={recentPosts} currentCategory={currentCategory} currentSubcategory={currentSubcategory} />
			<div class="site-content">
				<slot />
			</div>
		</div>
	</body>
</html>

<style>
	.site-layout {
		display: flex;
		align-items: flex-start;
		min-height: 100vh;
	}

	.site-content {
		flex: 1;
		min-width: 0;
	}
</style>
