---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { getBlogDataset } from '../data/blog';
import BlogSectionLayout from './BlogSectionLayout.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage, category } = Astro.props;
const { recentPosts, searchEntries, categorySummaries } = await getBlogDataset();
---

<BlogSectionLayout
	title={title}
	description={description}
	searchEntries={searchEntries}
	categorySummaries={categorySummaries}
	recentPosts={recentPosts}
	currentCategory={category}
	mainClass="post-main"
>
	<article>
		{heroImage && (
			<div class="hero-image">
				<Image width={1020} height={510} src={heroImage} alt="" />
			</div>
		)}
		<div class="post-header">
			<div class="post-meta-row">
				<FormattedDate date={pubDate} />
				{category && <span class="post-category">{category}</span>}
				{updatedDate && (
					<span class="updated-on">
						수정: <FormattedDate date={updatedDate} />
					</span>
				)}
			</div>
			<h1>{title}</h1>
			{description && <p class="post-description">{description}</p>}
			<hr />
		</div>
		<div class="prose-content">
			<slot />
		</div>
	</article>

	<aside slot="pageAside" class="toc-sidebar">
		<div class="toc-section" id="toc-container">
			<h3 class="toc-title">목차</h3>
			<ul class="toc-list" id="toc-list"></ul>
			<p class="toc-empty" id="toc-empty">헤딩이 없습니다.</p>
		</div>
	</aside>
</BlogSectionLayout>

<style>
	/* ── TOC sidebar: independent flex child of page-wrapper ── */
	.toc-sidebar {
		flex-shrink: 0;
		width: 250px;
		position: sticky;
		top: var(--header-height);
		align-self: flex-start;
		max-height: calc(100vh - 100px);
		overflow-y: auto;
		scrollbar-width: thin;
		scrollbar-color: var(--border) transparent;
		margin-left: 6rem;
	}

	.toc-section {
		border-top: 1px solid var(--border);
		padding-top: 1.25rem;
	}

	.toc-title {
		font-size: 0.82em;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.06em;
		color: var(--text-muted);
		margin: 0 0 0.9rem 0;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--border);
	}

	.toc-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.2rem;
	}

	.toc-empty {
		font-size: 0.8em;
		color: var(--text-muted);
		margin: 0;
		display: none;
	}

	:global(.toc-h3) {
		padding-left: 1.2em;
	}

	/* ── Post main ─────────────────────── */
	.post-main {
		padding: 0 0 2rem 0;
	}

	.hero-image {
		width: 100%;
		margin-bottom: 2rem;
	}
	.hero-image img {
		display: block;
		width: 100%;
		border-radius: 12px;
		border: 1px solid var(--border);
	}

	.post-header {
		margin-bottom: 2rem;
	}

	.post-meta-row {
		display: flex;
		align-items: center;
		flex-wrap: wrap;
		gap: 0.5em;
		font-size: 0.875em;
		color: var(--text-muted);
		margin-bottom: 0.75rem;
	}

	.post-category {
		background: var(--accent-dim);
		color: var(--accent);
		border-radius: 4px;
		padding: 0.1em 0.5em;
		font-size: 0.9em;
	}

	.updated-on {
		font-style: italic;
	}

	h1 {
		font-size: 2em;
		font-weight: 700;
		color: var(--text);
		margin: 0 0 0.5rem 0;
		line-height: 1.2;
	}

	.post-description {
		font-size: 1em;
		color: var(--text-muted);
		margin: 0 0 1.25rem 0;
	}

	hr {
		border: none;
		border-top: 1px solid var(--border);
		margin: 1.25rem 0 2rem 0;
	}

	.prose-content :global(h2),
	.prose-content :global(h3),
	.prose-content :global(h4) {
		scroll-margin-top: var(--header-height);
	}

	/* ── Responsive ─────────────────────── */
	@media (max-width: 768px) {
		.toc-sidebar {
			display: none;
		}
	}
</style>

<script>
	function buildToc() {
		const article = document.querySelector('.prose-content');
		const tocList = document.getElementById('toc-list');
		const tocEmpty = document.getElementById('toc-empty');

		if (!article || !tocList) return;

		const headings = article.querySelectorAll('h2, h3');

		if (headings.length === 0) {
			if (tocEmpty) tocEmpty.style.display = 'block';
			return;
		}

		headings.forEach((heading) => {
			const el = heading as HTMLElement;
			if (!el.id) {
				el.id = el.textContent?.toLowerCase().replace(/\s+/g, '-').replace(/[^\w-]/g, '') ?? '';
			}
			const li = document.createElement('li');
			const a = document.createElement('a');
			a.href = `#${el.id}`;
			a.textContent = el.textContent;
			a.className = `sidebar-nav-item toc-item ${el.tagName === 'H3' ? 'toc-h3' : 'toc-h2'}`;
			li.appendChild(a);
			tocList.appendChild(li);
		});

		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					const id = (entry.target as HTMLElement).id;
					const link = tocList.querySelector<HTMLAnchorElement>(`a[href="#${id}"]`);
					if (link && entry.isIntersecting) {
						tocList.querySelectorAll('a').forEach((a) => a.classList.remove('active'));
						link.classList.add('active');
					}
				}
			},
			{ rootMargin: '-10% 0% -75% 0%' },
		);

		headings.forEach((h) => {
			if ((h as HTMLElement).id) observer.observe(h);
		});
	}

	document.addEventListener('DOMContentLoaded', buildToc);
</script>
